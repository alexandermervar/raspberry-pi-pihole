pihole.toml
cli_pwconfig_backup

# Regeneratable / large Pi-hole artifacts
config/pihole/lists/
config/pihole/gravity_backups/
config/pihole/Cache/
config/pihole/migration_backup/
config/pihole/dhcp.leases
